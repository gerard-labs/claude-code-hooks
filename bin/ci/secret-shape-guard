#!/usr/bin/env bash
# SEC-15 — block secret-shaped strings from being committed in fixtures.
# Patterns are tightened for low false-positive against rendered HTML pages.
#
# Usage: bin/ci/secret-shape-guard <dir>...
set -euo pipefail

if [ "$#" -eq 0 ]; then
    echo "::error::secret-shape-guard requires at least one directory argument"
    exit 2
fi

# Each pattern alternates a strict shape that can't legitimately appear in templates.
# The OpenAI sk-* alternative requires BOTH an uppercase letter AND a digit in the body
# so common CSS fragments like `sk-position` don't fire.
PATTERN='(AKIA[0-9A-Z]{16}|ASIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{36}|xoxb-[A-Za-z0-9-]{20,}|xoxp-[A-Za-z0-9-]{20,}|sk-[A-Za-z0-9]*[A-Z][A-Za-z0-9]*[0-9][A-Za-z0-9]{8,}|eyJ[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+|Bearer [A-Za-z0-9._-]{20,}|gha_[A-Za-z0-9]{20,}|glpat-[A-Za-z0-9_-]{16,}|-----BEGIN [A-Z ]+PRIVATE KEY-----)'

OFFENDERS=""
for dir in "$@"; do
    [ -d "$dir" ] || continue
    FOUND=$(grep -nEr --binary-files=without-match "$PATTERN" "$dir" 2>/dev/null || true)
    if [ -n "$FOUND" ]; then
        OFFENDERS="${OFFENDERS}"$'\n'"${FOUND}"
    fi
done

if [ -n "$OFFENDERS" ]; then
    echo "::error::SEC-15 — secret-shaped strings detected in committed fixtures"
    echo "$OFFENDERS"
    exit 1
fi
